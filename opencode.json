{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-4o",
  "instructions": [
    "CLAUDE.md",
    ".github/copilot-instructions.md"
  ],
  "test": {
    "command": "npm test",
    "files": ["tests/**/*.test.js"],
    "coverage": {
      "threshold": {
        "statements": 85,
        "branches": 80,
        "functions": 90,
        "lines": 85
      }
    }
  },
  "lint": {
    "command": "npm run lint"
  },
  "format": {
    "command": "npm run format:check"
  },
  "build": {
    "command": "npm run build"
  }
}