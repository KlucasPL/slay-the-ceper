{
  "name": "slay-the-ceper",
  "version": "1.7.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "lhci": "lhci autorun",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:css:dupes",
    "lint:js": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "lint:css:dupes": "node scripts/check-css-duplicate-blocks.js",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim:smoke": "node scripts/sim/smoke.js",
    "sim": "node scripts/sim/index.js",
    "sim:diff": "node scripts/sim/tools/diff-baseline.js",
    "sim:replay": "node scripts/sim/replay.js",
    "analyze": "node --max-old-space-size=6144 scripts/analyze.js",
    "rpc": "node scripts/rpc-server.js",
    "mcp": "node scripts/mcp-server.js",
    "bench:sim": "node bench/runOneGame.bench.js",
    "dashboard:vendor": "mkdir -p tools/dashboard/vendor && cp node_modules/chart.js/dist/chart.umd.min.js tools/dashboard/vendor/chart.umd.min.js",
    "precommit": "npm run format:check && npm run lint"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.22.0",
    "@lhci/cli": "^0.15.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^3.2.4",
    "chart.js": "^4.5.1",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "jsdom": "^24.1.3",
    "prettier": "^3.5.3",
    "stylelint": "^16.25.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "gameanalytics": "^4.4.7"
  }
}
